{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "[Tests] Perimortem (Linux)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/.bin/bin/validation/unit_tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      // Why are you like this VSCode???
      "sourceMap": {
        "/proc/self/cwd/external/": "${workspaceFolder}/.bin/Perimortem/external/",
        "/proc/self/cwd/": "${workspaceFolder}"
      },
      "initCommands": [
        "command source '${workspaceFolder}/.vscode/perimortem.lldb'"
      ],
      "preLaunchTask": "Full Build (Linux) [Debug]",
      "presentation": {
        "clear": true
      }
    },
    {
      "name": "[Tests] Lsp (Linux)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/.bin/bin/tetrodotoxin/lsp/server/tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      // Why are you like this VSCode???
      "sourceMap": {
        "/proc/self/cwd/external/": "${workspaceFolder}/.bin/Perimortem/external/",
        "/proc/self/cwd/": "${workspaceFolder}"
      },
      "initCommands": [
        "command source '${workspaceFolder}/.vscode/perimortem.lldb'"
      ],
      "preLaunchTask": "Full Build (Linux) [Debug]",
      "presentation": {
        "clear": true
      }
    },
    {
      "name": "[Benchmarks] Run All (Linux)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/.bin/bin/validation/benchmarks",
      "args": [],
      "cwd": "${workspaceFolder}",
      // Why are you like this VSCode???
      "sourceMap": {
        "/proc/self/cwd/external/": "${workspaceFolder}/.bin/Perimortem/external/",
        "/proc/self/cwd/": "${workspaceFolder}"
      },
      "initCommands": [
        "command source '${workspaceFolder}/.vscode/perimortem.lldb'"
      ],
      "preLaunchTask": "Full Build (Linux) [Release]",
      "presentation": {
        "clear": true
      }
    },
    {
      "name": "[Benchmarks] Run All w/ C++ (Linux)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/.bin/bin/validation/benchmarks",
      "args": [],
      "cwd": "${workspaceFolder}",
      // Why are you like this VSCode???
      "sourceMap": {
        "/proc/self/cwd/external/": "${workspaceFolder}/.bin/Perimortem/external/",
        "/proc/self/cwd/": "${workspaceFolder}"
      },
      "initCommands": [
        "command source '${workspaceFolder}/.vscode/perimortem.lldb'"
      ],
      "preLaunchTask": "Full Build w/ C++ (Linux) [Release]",
      "presentation": {
        "clear": true
      }
    },
    {
      "name": "[Lsp] Launch TTX client",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "${workspaceFolder}/tetrodotoxin/tests/scripts/",
        "--extensionDevelopmentPath=${workspaceRoot}/tetrodotoxin/lsp/client/"
      ],
      "outFiles": [
        "${workspaceRoot}/out/**/*.js",
        "${workspaceRoot}/server/out/**/*.js"
      ],
      "autoAttachChildProcesses": true,
      "preLaunchTask": "TTX Lsp Build",
    },
  ]
}
