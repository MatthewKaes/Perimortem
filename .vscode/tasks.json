{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Full Build (Linux) [Debug]",
      "type": "shell",
      "command": "bazel",
      "problemMatcher": [
        "$gcc"
      ],
      "args": [
        "build",
        "...",
        "--config=debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Performs a full Bazel build of the Platform.",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "Full Build (Linux) [Release]",
      "type": "shell",
      "command": "bazel",
      "problemMatcher": [
        "$gcc"
      ],
      "args": [
        "build",
        "...",
        "--config=release"
      ],
      "group": "build",
      "detail": "Performs a full Bazel build of the Platform.",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "Full Build w/ C++ (Linux) [Release]",
      "type": "shell",
      "command": "bazel",
      "problemMatcher": [
        "$gcc"
      ],
      "args": [
        "build",
        "...",
        "--config=release",
        "--define",
        "PERI_BENCH_CPP=1"
      ],
      "group": "build",
      "detail": "Performs a full Bazel build of the Platform.",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "TTX Lsp Install",
      "type": "npm",
      "script": "install",
      "group": "build",
      "detail": "Performs a npm install of TTX Lsp dependencies.",
      "presentation": {
        "clear": true,
      },
      "options": {
        "cwd": "${workspaceFolder}/tetrodotoxin/lsp/client/"
      },
      "dependsOn": "Full Build (Linux) [Debug]"
    },
    {
      "label": "TTX Lsp Build",
      "type": "npm",
      "script": "compile",
      "group": "build",
      "detail": "Performs a build of the TTX Lsp extension.",
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "never"
      },
      "problemMatcher": [
        "$tsc"
      ],
      "options": {
        "cwd": "${workspaceFolder}/tetrodotoxin/lsp/client/"
      },
      "dependsOn": "TTX Lsp Install"
    }
  ]
}
