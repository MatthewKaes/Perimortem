{
  "name": "Tetrodotoxin",
  "scopeName": "source.tetrodotoxin",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#disabled"
    },
    {
      "include": "#storage_sigils"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#language_constants"
    },
    {
      "include": "#discard"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtin_types"
    },
    {
      "include": "#declaration_name"
    },
    {
      "include": "#type_member_access"
    },
    {
      "include": "#member_access"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.tetrodotoxin",
      "match": "//.*$"
    },
    "disabled": {
      "name": "comment.line.disabled.tetrodotoxin",
      "match": "/>.*$"
    },
    "storage_sigils": {
      "name": "storage.sigils.tetrodotoxin",
      "match": "\\b(frozen|detail|public|expose|hidden|stack|import)\\b"
    },
    "attributes": {
      "name": "entity.other.attribute-name.tetrodotoxin",
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "strings": {
      "name": "string.quoted.double.tetrodotoxin",
      "match": "\"[^\"]*\"(?:_[a-z]+)?"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex-array.tetrodotoxin",
          "match": "0x\\[[0-9A-Fa-f \\t]+\\]"
        },
        {
          "name": "constant.numeric.hex.tetrodotoxin",
          "match": "0x[0-9A-Fa-f]+"
        },
        {
          "name": "constant.numeric.float.tetrodotoxin",
          "match": "\\b[0-9]+\\.[0-9]+"
        },
        {
          "name": "constant.numeric.integer.tetrodotoxin",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "discard": {
      "name": "keyword.other.discard.tetrodotoxin",
      "match": "(?<![A-Za-z0-9_])_(?![A-Za-z0-9_])"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tetrodotoxin",
          "match": "\\b(for|in|match|case|if|else|return|while|break|continue|true|false)\\b"
        },
        {
          "name": "keyword.other.tetrodotoxin",
          "match": "\\b(package|self|args)\\b"
        }
      ]
    },
    "builtin_types": {
      "name": "support.type.tetrodotoxin",
      "match": "(?<![A-Za-z0-9_])(Bits_(?:8|16|32|64)|Signed_(?:8|16|32|64)|Real_(?:32|64|128)|Bool|Bytes|List|Vec(?:2|3|4)D|Vec|Layout|View|Access|Fragment|Const|Sampler_2D|Foreign|Object|Struct|Func|Enum|Alias|Shader|Library|TTX)(?![A-Za-z0-9_])"
    },
    "declaration_name": {
      "name": "entity.name.class.tetrodotoxin",
      "match": "\\b[A-Z][a-zA-Z0-9_]*(?=\\s*:)"
    },
    "type_member_access": {
      "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.)([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "entity.name.type.caller.tetrodotoxin"
        },
        "2": {
          "name": "punctuation.accessor.tetrodotoxin"
        },
        "3": {
          "name": "entity.name.type.member.tetrodotoxin"
        }
      }
    },
    "member_access": {
      "name": "variable.other.member.tetrodotoxin",
      "match": "(?<=\\.)([a-z_][a-zA-Z0-9_]*)"
    },
    "functions": {
      "match": "(->)\\s*([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.accessor.tetrodotoxin"
        },
        "2": {
          "name": "entity.name.function.tetrodotoxin"
        }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.accessor.tetrodotoxin",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.tetrodotoxin",
          "match": "\\.{3}(=)?"
        },
        {
          "name": "keyword.operator.tetrodotoxin",
          "match": "=>|==|!=|<=|>=|&&|\\|\\||[+\\-*/%^&|!<>=]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.braces.tetrodotoxin",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.tetrodotoxin",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.tetrodotoxin",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.terminator.statement.tetrodotoxin",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.tetrodotoxin",
          "match": ","
        },
        {
          "name": "punctuation.accessor.tetrodotoxin",
          "match": "->|:|\\."
        }
      ]
    },
    "types": {
      "name": "entity.name.type.tetrodotoxin",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    }
  }
}
