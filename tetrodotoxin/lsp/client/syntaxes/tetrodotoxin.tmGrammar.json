{
  "name": "Tetrodotoxin",
  "scopeName": "source.tetrodotoxin",
  "patterns": [
    {
      "include": "#common"
    }
  ],
  "repository": {
    "common": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#disabled"
        },
        {
          "include": "#compile_if"
        },
        {
          "include": "#storage_sigils"
        },
        {
          "include": "#attributes"
        },
        {
          "include": "#embedded"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#language_constants"
        },
        {
          "include": "#control_keywords"
        },
        {
          "include": "#shared_keywords"
        },
        {
          "include": "#discard"
        },
        {
          "include": "#builtin_types"
        },
        {
          "include": "#function_declarations"
        },
        {
          "include": "#function_calls"
        },
        {
          "include": "#declaration_name"
        },
        {
          "include": "#type_member_access"
        },
        {
          "include": "#member_access"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#punctuation"
        },
        {
          "include": "#types"
        }
      ]
    },
    "comments": {
      "name": "comment.line.double-slash.tetrodotoxin",
      "match": "//.*$"
    },
    "disabled": {
      "name": "comment.line.disabled.tetrodotoxin",
      "match": "/>.*$"
    },
    "compile_if": {
      "match": "(@)(if)\\b",
      "captures": {
        "1": {
          "name": "storage.sigils.tetrodotoxin"
        },
        "2": {
          "name": "keyword.control.tetrodotoxin"
        }
      }
    },
    "storage_sigils": {
      "name": "storage.sigils.tetrodotoxin",
      "match": "(@(?:public|expose|hidden|stack)\\b|\\b(?:public|expose|hidden|stack)\\b)"
    },
    "attributes": {
      "name": "entity.other.attribute-name.tetrodotoxin",
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "embedded": {
      "patterns": [
        {
          "name": "string.other.embedded.tetrodotoxin",
          "match": "\\$\\[[^\\]]*\\]"
        },
        {
          "name": "constant.numeric.hex-array.tetrodotoxin",
          "match": "0x\\[[0-9A-Fa-f \\t\\r\\n]+\\]"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.tetrodotoxin",
      "match": "\"[^\"]*\"(?:_[a-z]+)?"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.tetrodotoxin",
          "match": "0x[0-9A-Fa-f]+"
        },
        {
          "name": "constant.numeric.float.tetrodotoxin",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.tetrodotoxin",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "language_constants": {
      "name": "constant.language.tetrodotoxin",
      "match": "\\b(true|false)\\b"
    },
    "discard": {
      "name": "keyword.other.discard.tetrodotoxin",
      "match": "(?<![A-Za-z0-9_])_(?![A-Za-z0-9_])"
    },
    "control_keywords": {
      "name": "keyword.control.tetrodotoxin",
      "match": "\\b(for|in|match|case|if|else|return|while|break|continue)\\b"
    },
    "shared_keywords": {
      "patterns": [
        {
          "name": "keyword.control.tetrodotoxin",
          "match": "\\b(and|or)\\b"
        },
        {
          "name": "keyword.other.tetrodotoxin",
          "match": "\\b(dialect|import|external|func|self|new|init|object|struct|enum|foreign|alias)\\b"
        }
      ]
    },
    "builtin_types": {
      "name": "support.type.tetrodotoxin",
      "match": "(?<![A-Za-z0-9_])(Bits_(?:8|16|32|64)|Signed_(?:8|16|32|64)|Real_(?:32|64|128)|Bool|Bytes|Count|Void|Text|Blob|List|Vec(?:2|3|4)D|Vec|Layout|View|Access|Fragment|Const|Sampler2D|Range|TTX)(?![A-Za-z0-9_])"
    },
    "function_declarations": {
      "match": "\\b(func)\\s+([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.other.tetrodotoxin"
        },
        "2": {
          "name": "entity.name.function.tetrodotoxin"
        }
      }
    },
    "function_calls": {
      "match": "(->)\\s*([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.accessor.tetrodotoxin"
        },
        "2": {
          "name": "entity.name.function.tetrodotoxin"
        }
      }
    },
    "declaration_name": {
      "name": "entity.name.class.tetrodotoxin",
      "match": "\\b[A-Z][a-zA-Z0-9_]*(?=\\s*:)"
    },
    "type_member_access": {
      "match": "\\b([A-Z][a-zA-Z0-9_]*)(::)([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "entity.name.type.caller.tetrodotoxin"
        },
        "2": {
          "name": "punctuation.accessor.tetrodotoxin"
        },
        "3": {
          "name": "entity.name.type.member.tetrodotoxin"
        }
      }
    },
    "member_access": {
      "patterns": [
        {
          "name": "variable.other.member.tetrodotoxin",
          "match": "(?<=\\.)([a-z_][a-zA-Z0-9_]*)"
        },
        {
          "name": "constant.numeric.indexed-field.tetrodotoxin",
          "match": "(?<=\\.)(0x[0-9A-Fa-f]+|[0-9]+)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.accessor.tetrodotoxin",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.tetrodotoxin",
          "match": "\\.{3}"
        },
        {
          "name": "keyword.operator.tetrodotoxin",
          "match": "\\.\\[|:\\[|::|==|!=|<=|>=|\\+=|-=|[+\\-*/%^&|!<>=]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.braces.tetrodotoxin",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.tetrodotoxin",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.tetrodotoxin",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.terminator.statement.tetrodotoxin",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.tetrodotoxin",
          "match": ","
        },
        {
          "name": "punctuation.accessor.tetrodotoxin",
          "match": ":|\\."
        }
      ]
    },
    "types": {
      "name": "entity.name.type.tetrodotoxin",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    }
  }
}
