dialect : Package;

import Types : Library = (.source = "library/types.ttx");
import Sprite : Library = (.source = "library/sprite.ttx");
import Render2D : Render = (.source = "renderers/renderer_2d.ttx");
import Default2D : Shader = (.source = "shaders/default_2d.ttx");

@public name : View[Bytes] = "TTX::Graphics";

@public Color : alias = Types::Color;
@public Sampler2D : alias = Types::Sampler2D;
@public Sprite : alias = Sprite::Sprite;

@public Renderer : Namespace {
  @public Renderer2D : alias = Render2D::Renderer2D;
}

@public Shaders : Namespace {
  @public Default2D : alias = Default2D;
}
