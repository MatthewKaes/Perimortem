// Minimal Graphics package used by resolver fixtures.
package : Library;

@expose Pixel : Struct {
  expose r : Bits_8;
  expose g : Bits_8;
  expose b : Bits_8;
  expose a : Bits_8;
}

@expose Image : Struct {
  expose pixels : List[Pixel];
  expose width  : Bits_32;
  expose height : Bits_32;

  @public func get_channel_count[] -> Count {
    return 4;
  }
}
