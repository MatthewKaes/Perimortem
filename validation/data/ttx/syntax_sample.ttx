// Syntax parser fixture
// Covers package, imports, definitions, expressions, and statements.
dialect : Library;

import Graphics : Library = ( .source = "graphics/image.ttx" );
import Core : Library = TTX.Core;

@extern(.abi = "c", .enabled = true)
@hidden ForeignApi : foreign {
  external @hidden func inflate[.source : View[Bytes], .capacity : Count] -> Bytes;
}

@hidden Color : enum[Bits_8](.red = 1, .green = 2);

@public func choose[] -> Count {
  match self {
    case Color.red: {
      return 1;
    }
    case _: {
      return 0;
    }
  }
}

@hidden empty : Void;
@hidden signature : Vec[Bits_8, 8] = 0x[89 50 4E 47];
@hidden greeting : Text = "hello";
@hidden ratio : Real_64 = 0.5;
@hidden embedded : Blob = $[validation/data/ttx/png.ttx];
@hidden config : Config = (.width = 4, .name = "main");
@hidden values : Vec[Bits_32, 4] = { 1, 2, 3, 4 };
@hidden span : Range = 0...4;
@hidden explicit_expression : Count = 3;
@hidden generated : Rows = { 0, 1 };

@public func transform[
  @builtin(.slot = 0) .source : View[Bytes],
  .count : Count,
  .name : Text,
] -> [
  .ok : Bool,
  .value : Count,
] {
  @stack total : Count = 0;
  @stack explicit : Count = Count -> from(1);
  total = total + count * 2 - 1 / 1 % 2;
  total += source -> get_size();
  total -= source[0];
  @stack pair : Pair = (total, name);
  @stack bytes : Vec[Bits_8, 4] = 0x[01 02 03 04];
  @stack text : Text = "hi";
  @stack flag : Bool = true and !false or count >= 1;
  @stack neg : Signed_32 = -1;
  @stack field : Count = package.version;
  field = source.[0 +: 2] -> get_size();
  field = source.[0, 1, 2] -> get_size();
  if (total > 10) {
    return (.ok = true, .value = total);
  } else if (total != 0) {
    total = total;
  } else {
    return;
  }
  while (total < count) {
    total += 1;
    continue;
  }
  for [.i : Count] in 0...count {
    total += i;
  }
  match total {
    case 0: {
      return (.ok = false, .value = 0);
    }
    case _: {
      total = total;
    }
  }
  @if(.enabled = true) {
    @stack temp : Count = 1;
  }
  source -> copy_to(_);
  return (.ok = true, .value = total);
}

@public Container : struct {
  // Field comment
  /> @packed
  @public width : Count = 1;
  @hidden data : Vec[Bits_8, 16];
}
