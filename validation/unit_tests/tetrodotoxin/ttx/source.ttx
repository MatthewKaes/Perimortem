dialect : Library;

@hidden Console : foreign {
  external @hidden func print[.data : View[Bytes]] -> [];
}

@hidden Receiver : foreign {
  external @hidden func receive_message[.message : Message] -> [];
  external @hidden func receive_pair[.left : Message, .right : Message] -> [];
}

@hidden Message : struct {
  @hidden title : View[Bytes];
  @hidden count : Bits_32;
  @hidden ratio : Real_32;
}

@public func tetrodotoxin_test[.data : View[Bytes]] -> [] {
  Console -> print("Compiler Test");
  Console -> print(data);
}

@public func structured_test[] -> [] {
  stack message : Message = (
    .title = "Structured",
    .count = 7,
    .ratio = -0.5,
  );
  Receiver -> receive_message(message);
}

@public func object_pair_test[] -> [] {
  stack left : Message;
  left.title = "Left";
  left.count = 2;
  left.ratio = 0.25;

  stack right : Message = (
    .title = "Right",
    .count = 3,
    .ratio = -0.75,
  );
  Receiver -> receive_pair(left, right);
}
